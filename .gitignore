# ──────────────────────────────────────────────────────────────────────────────
# Dependencies
# ──────────────────────────────────────────────────────────────────────────────
node_modules/

# ──────────────────────────────────────────────────────────────────────────────
# Build output
# ──────────────────────────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ──────────────────────────────────────────────────────────────────────────────
# Environment variables — NEVER commit; copy .env.example to .env to get started
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ──────────────────────────────────────────────────────────────────────────────
# Runtime data — generated automatically at startup
# ──────────────────────────────────────────────────────────────────────────────
# File-based session store (express-session / session-file-store)
sessions/
# Persistent data written by the backend at runtime (e.g. iCal subscriptions)
backend/data/

# ──────────────────────────────────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────────────────────────────────────────────────────
# OS / editor artefacts
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
Claude.md 
Antigravity.md

# ──────────────────────────────────────────────────────────────────────────────
# Vite dev cache
# ──────────────────────────────────────────────────────────────────────────────
frontend/.vite/
